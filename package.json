{
  "name": "piano-ai-practice",
  "private": true,
  "version": "0.1.0",
  "description": "A local-first piano practice, score analysis, and reference performance research tool.",
  "author": "Mike Zhl",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikezhl/PianoAI.git"
  },
  "bugs": {
    "url": "https://github.com/mikezhl/PianoAI/issues"
  },
  "homepage": "https://github.com/mikezhl/PianoAI#readme",
  "type": "module",
  "engines": {
    "node": "^22.12.0 || >=24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run analysis:validate && npm run performance:validate && npm run agent:guide:check && npm run typecheck && vite build --mode online",
    "build:local": "npm run analysis:validate && npm run performance:validate && npm run agent:guide:check && npm run typecheck && vite build --mode offline",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run --environment jsdom",
    "typecheck": "tsc -b",
    "check": "npm run analysis:validate && npm run performance:validate && npm run agent:guide:check && npm test -- --run && npm run typecheck",
    "agent:guide": "tsx tools/agent/generate-agent-guide.ts",
    "agent:guide:check": "tsx tools/agent/generate-agent-guide.ts --check",
    "analysis:chords": "tsx tools/score-analysis/generate-left-hand-chords.ts",
    "analysis:inspect": "python tools/score-analysis/inspect_score.py",
    "analysis:validate": "python tools/score-analysis/validate_manifest.py --require-complete && npm run analysis:chords -- --check",
    "performance:generate": "tsx tools/performance/generate-reference-performance.ts --all",
    "performance:generate:cached": "tsx tools/performance/generate-reference-performance.ts --all --reuse-transcriptions",
    "performance:generate:planned": "tsx tools/performance/generate-reference-batch.ts",
    "performance:compare": "tsx tools/performance/analyze-reference-style.ts",
    "performance:index": "tsx tools/performance/generate-reference-source-index.ts",
    "performance:finalize": "npm run performance:validate && npm run performance:index && npm run performance:compare",
    "performance:collect": "tsx tools/performance/collect-reference-audio.ts --all",
    "performance:setup": "npm run performance:setup:alignment && npm run performance:setup:transcription",
    "performance:setup:alignment": "tsx tools/performance/setup-score-alignment.ts",
    "performance:setup:transcription": "tsx tools/performance/setup-piano-transcription.ts",
    "performance:doctor": "tsx tools/performance/check-performance-environment.ts",
    "performance:validate": "tsx tools/performance/validate-performance-references.ts",
    "performance:r2:sync": "tsx tools/performance/sync-reference-audio-r2.ts"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "lucide-react": "^1.23.0",
    "opensheetmusicdisplay": "^2.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tone": "^15.1.22"
  },
  "devDependencies": {
    "@tonaljs/chord-detect": "^4.9.1",
    "@tonaljs/note": "^4.12.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "ajv": "^8.20.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
