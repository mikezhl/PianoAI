{
  "name": "piano-ai-practice",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run analysis:validate && tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run --environment jsdom",
    "analysis:chords": "tsx analysis/scripts/generate-left-hand-chords.ts",
    "analysis:inspect": "python .agents/skills/piano-score-analysis/scripts/inspect_score.py",
    "analysis:validate": "python .agents/skills/piano-score-analysis/scripts/validate_manifest.py --require-complete && npm run analysis:chords -- --check"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "lucide-react": "^1.23.0",
    "opensheetmusicdisplay": "^2.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tone": "^15.1.22"
  },
  "devDependencies": {
    "@tonaljs/chord-detect": "^4.9.1",
    "@tonaljs/note": "^4.12.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
